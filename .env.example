# ──────────────────────────────────────────────
# متغيرات بيئة igris Bot — انسخ هذا الملف إلى .env وأكمل القيم
# ──────────────────────────────────────────────

# Fix 1: اسم المتغير هنا يطابق ما يقرؤه utils/session.js
# القيمة: base64 لمحتوى appstate.json (شغّل: node generate-appstate.js appstate.json)
APPSTATE_JSON=<base64_encoded_appstate_json>

# Fix 9: معرّفات فيسبوك للمشرفين، مفصولة بفاصلة
ADMIN_IDS=<uid1>,<uid2>

# Fix 9: اسم مستودع GitHub لجلب appstate.json منه عند فشل القراءة المحلية
GH_REPO=<github_username>/<repo_name>

# توكن GitHub لقراءة appstate.json من المستودع الخاص
GH_TOKEN=<github_personal_access_token>
